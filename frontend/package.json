{
	"name": "frontend",
	"version": "0.1.0",
	"private": true,
	"homepage": "./",
	"main": "electron.js",
	"dependencies": {
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@mui/icons-material": "^7.3.5",
		"@mui/material": "^7.3.5",
		"@mui/x-date-pickers": "^8.17.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^13.5.0",
		"@tiptap/extension-placeholder": "^3.15.3",
		"@tiptap/extension-underline": "^3.15.3",
		"@tiptap/react": "^3.15.3",
		"@tiptap/starter-kit": "^3.15.3",
		"@types/jest": "^27.5.2",
		"@types/node": "^16.18.126",
		"@types/react": "^19.2.2",
		"@types/react-dom": "^19.2.2",
		"dayjs": "^1.11.19",
		"jspdf": "^4.2.0",
		"lucide-react": "^0.548.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-pro-sidebar": "^1.1.0",
		"react-router-dom": "^7.9.5",
		"react-scripts": "5.0.1",
		"react-use-websocket": "^4.13.0",
		"typescript": "^4.9.5",
		"web-vitals": "^2.1.4"
	},
	"scripts": {
		"start": "concurrently \"npm run start-react\" \"npm run start-electron\"",
		"start-react": "cross-env BROWSER=none react-scripts start",
		"start-electron": "wait-on http://localhost:3000 && node node_modules/electron/cli.js .",
		"build-backend-linux": "cd ../backend && uv run --with pyinstaller pyinstaller --onefile --name pulsenotes-backend --collect-binaries llama_cpp --collect-data llama_cpp run_backend.py",
		"build-backend-mac": "cd ../backend && uv run --with pyinstaller pyinstaller --onefile --name pulsenotes-backend --collect-binaries llama_cpp --collect-data llama_cpp run_backend.py",
		"build-backend-win": "cd ../backend && uv run --with pyinstaller pyinstaller --onefile --name pulsenotes-backend --collect-binaries llama_cpp --collect-data llama_cpp run_backend.py",
		"build": "react-scripts build",
		"build-electron": "electron-builder",
		"package-linux": "npm run build-backend-linux && npm run build && npm run build-electron -- --linux AppImage --config.directories.output=dist-linux",
		"package-mac": "npm run build-backend-mac && npm run build && npm run build-electron -- --mac dmg --config.directories.output=dist-mac",
		"package-win": "npm run build-backend-win && npm run build && npm run build-electron -- --win nsis --config.directories.output=dist-win",
		"test": "react-scripts test",
		"eject": "react-scripts eject",
		"lint-format": "npx @biomejs/biome check --write"
	},
	"build": {
		"appId": "com.pulsenotes.app",
		"productName": "PulseNotes",
		"extraMetadata": {
			"main": "electron.js"
		},
		"files": [
			"build/**/*",
			"electron.js",
			"preload.js",
			"package.json",
			"public/**/*"
		],
		"extraResources": [
			{
				"from": "../backend/.env",
				"to": "backend/.env"
			}
		],
		"win": {
			"target": [
				"nsis"
			],
			"extraResources": [
				{
					"from": "../backend/dist/pulsenotes-backend.exe",
					"to": "backend/pulsenotes-backend.exe"
				}
			]
		},
		"linux": {
			"target": [
				"AppImage"
			],
			"category": "Utility",
			"extraResources": [
				{
					"from": "../backend/dist/pulsenotes-backend",
					"to": "backend/pulsenotes-backend"
				}
			]
		},
		"mac": {
			"target": [
				"dmg"
			],
			"category": "public.app-category.medical",
			"extraResources": [
				{
					"from": "../backend/dist/pulsenotes-backend",
					"to": "backend/pulsenotes-backend"
				}
			],
			"extendInfo": {
				"NSMicrophoneUsageDescription": "PulseNotes needs microphone access for speech-to-text transcription."
			}
		}
	},
	"eslintConfig": {
		"extends": [
			"react-app",
			"react-app/jest"
		]
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.4",
		"concurrently": "^9.2.1",
		"cross-env": "^10.1.0",
		"electron": "^39.0.0",
		"electron-builder": "^25.1.8",
		"wait-on": "^9.0.1"
	}
}
